# SSH target VM
VM_HOST=192.168.1.100
VM_PORT=22
VM_USER=youruser
VM_PWORD=yourpassword

# Web server port (optional, default 3000)
PORT=3000

# xAI / Grok API key — get yours at https://console.x.ai
XAI_API_KEY=xai-...

# Model used for CLI command generation (chat completions)
XAI_GENERATE_MODEL=grok-3-mini

# Google OAuth (required for auth guard)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Session secret — use any long random string
SESSION_SECRET=change-me-to-something-random
